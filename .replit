hidden=[ ".config" ]
modules = ["python-3.11"]

[nix]
channel = "stable-22_11"

# Development Server Configuration
[deployment]
run = "python main.py"

[languages.python]
pattern = "**/*.py"

[languages.python.languageServer]
start = "pyright-langserver --stdio"

[languages.python.languageServer.initializationOptions]
provideFormatter = true

[languages.python.languageServer.configuration.python]
analysis.typeCheckingMode = "basic"
analysis.autoSearchPaths = true
analysis.useLibraryCodeForTypes = true

[languages.python.languageServer.configuration.python.formatting]
provider = "black"

[languages.python.languageServer.configuration.python.linting]
enabled = true
pylintEnabled = true

# Environment variables required for Flask debugging
[env]
FLASK_APP = "main.py"
FLASK_ENV = "development"
FLASK_DEBUG = "1"

[gitHubImport]
requiredFiles = [ ".replit" , "replit.nix" , ".config" ]

[[ports]]
localPort = 8080
externalPort = 80

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "FullStack"
mode = "parallel"
author = 17955053

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main.py"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "source venv/bin/activate && python main.py"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "DISPLAY=:0 python main.py"

[agent]
expertMode = true
